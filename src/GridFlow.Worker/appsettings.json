{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "EnergiDataService": {
    "BaseUrl": "https://api.energidataservice.dk/",
    "Dataset": "Gasflow",
    "DefaultLimit": 100
  },
  "Ingestion": {
    "Interval": "06:00:00",
    "Window": "7.00:00:00"
  }
}
